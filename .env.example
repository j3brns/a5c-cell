# Platform Environment Variables
# Copy to .env.local and fill in values
# See docs/development/PLATFORM-SETUP.md for where to find each value

# Entra app registration (from Azure Portal)
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_SCOPES=

# API endpoint (from CDK outputs after infra-deploy, or team-platform Slack)
VITE_API_BASE_URL=

# GitLab project ID (from GitLab project settings)
GITLAB_PROJECT_ID=

# AWS Account IDs
AWS_REGION=eu-west-2
AWS_DEFAULT_REGION=eu-west-2
AWS_CONTROL_ACCOUNT_ID=
AWS_RUNTIME_ACCOUNT_ID=

# Local development only (set these for `make dev`)
MOCK_RUNTIME=true
AWS_ENDPOINT_URL=http://localhost:4566
LOCAL_AWS_EMULATOR_IMAGE=docker.io/floci/floci:latest
LOCAL_AWS_HEALTH_URL=http://localhost:4566/_localstack/health
PLATFORM_ENV=local
# Generate with: openssl rand -hex 32
SCOPED_TOKEN_SIGNING_KEY=
