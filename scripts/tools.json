{
  "tools": [
    {
      "name": "aws",
      "version": "2.15.30",
      "description": "AWS Command Line Interface v2",
      "platforms": {
        "x86_64": {
          "url": "https://awscli.amazonaws.com/awscli-exe-linux-x86_64-2.15.30.zip",
          "sha256": "023588dd585299ea78bec7452152bb8cb15eebd44e9f0a0838f0cdaac1b087f6"
        }
      },
      "install_command": "chmod +x ./aws/install && sudo ./aws/install --install-dir {install_dir} --bin-dir {bin_dir} --update",
      "binary": "aws"
    },
    {
      "name": "glab",
      "version": "1.53.0",
      "description": "GitLab CLI",
      "platforms": {
        "x86_64": {
          "url": "https://gitlab.com/gitlab-org/cli/-/releases/v1.53.0/downloads/glab_1.53.0_linux_amd64.tar.gz",
          "sha256": "e6b8bf7144cf4215a7a3e208ba049c27fb444d23aa28d738cc7ee990058cbb2f"
        }
      },
      "install_command": "cp bin/glab {bin_dir}/glab && chmod +x {bin_dir}/glab",
      "binary": "glab"
    },
    {
      "name": "cfn-guard",
      "version": "3.2.0",
      "description": "CloudFormation Guard",
      "platforms": {
        "x86_64": {
          "url": "https://github.com/aws-cloudformation/cloudformation-guard/releases/download/3.2.0/cfn-guard-v3-x86_64-linux-latest.tar.gz",
          "sha256": "c78f7a1a6c2674f7edbf0ebdc0590126487a14b103e434aea31205a4d1034d21"
        }
      },
      "install_command": "cp */cfn-guard {bin_dir}/cfn-guard && chmod +x {bin_dir}/cfn-guard",
      "binary": "cfn-guard"
    },
    {
      "name": "claude",
      "version": "0.2.29",
      "description": "Claude Code CLI",
      "type": "npm",
      "package": "@anthropic-ai/claude-code",
      "binary": "claude"
    }
  ]
}
